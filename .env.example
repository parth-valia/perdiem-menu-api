# Square Sandbox credentials — never use production keys here
SQUARE_ACCESS_TOKEN=your_sandbox_access_token_here
SQUARE_ENVIRONMENT=sandbox

# Server config
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:3000

# Cache TTL in seconds (catalog data is slow-changing, 5 min is safe)
CACHE_TTL_SECONDS=300
